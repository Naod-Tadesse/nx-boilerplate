{
  "name": "@org/database",
  "version": "0.0.1",
  "private": true,
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./package.json": "./package.json"
  },
  "nx": {
    "targets": {
      "build": {
        "executor": "nx:run-commands",
        "options": {
          "command": "tsc -b tsconfig.lib.json",
          "cwd": "packages/database"
        },
        "outputs": ["{projectRoot}/dist"],
        "cache": true
      },
      "db:generate": {
        "command": "drizzle-kit generate --config=packages/database/drizzle.config.ts",
        "options": {
          "cwd": "{workspaceRoot}"
        }
      },
      "db:migrate": {
        "command": "drizzle-kit migrate --config=packages/database/drizzle.config.ts",
        "options": {
          "cwd": "{workspaceRoot}"
        }
      },
      "db:push": {
        "command": "drizzle-kit push --config=packages/database/drizzle.config.ts",
        "options": {
          "cwd": "{workspaceRoot}"
        }
      },
      "db:studio": {
        "command": "drizzle-kit studio --config=packages/database/drizzle.config.ts",
        "options": {
          "cwd": "{workspaceRoot}"
        }
      },
      "db:seed": {
        "command": "tsx packages/database/src/lib/seed/seed.ts",
        "options": {
          "cwd": "{workspaceRoot}"
        }
      }
    }
  },
  "dependencies": {}
}
