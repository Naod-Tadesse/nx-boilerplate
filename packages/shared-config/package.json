{
  "name": "@org/shared-config",
  "version": "0.0.1",
  "private": true,
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./package.json": "./package.json"
  },
  "nx": {
    "targets": {
      "build": {
        "executor": "nx:run-commands",
        "options": {
          "command": "tsc -b tsconfig.lib.json",
          "cwd": "packages/shared-config"
        },
        "outputs": ["{projectRoot}/dist"],
        "cache": true
      }
    }
  },
  "dependencies": {}
}
